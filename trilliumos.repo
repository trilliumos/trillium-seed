# trilliumOS COPR repo from sassam used to install the 6.18.0-65 ELN `kernel`, btrfs-progs and
# other packages required for trilliumOS.
[trilliumos]
name=Copr repo for trilliumOS owned by sassam
baseurl=https://download.copr.fedorainfracloud.org/results/sassam/trilliumOS/epel-10-$basearch/
type=rpm-md
skip_if_unavailable=False
gpgcheck=1
gpgkey=https://download.copr.fedorainfracloud.org/results/sassam/trilliumOS/pubkey.gpg
repo_gpgcheck=0
enabled=1
enabled_metadata=1